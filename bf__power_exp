import numpy as np
import sounddevice as sd
import whisper
import time
import sys

# --- [실험 설정] ---
RATE = 16000
CHANNELS = 2
RECORD_SEC = 5.0
MODEL_SIZE = "base"
TRIALS = 3 

# 📍 실험 목록
EXPERIMENT_LIST = [
    "20cm_0도_소음X",
    "40cm_0도_소음X",
    "40cm_45도_소음X",
    "40cm_90도_소음X",
    "20cm_정면_40cm_0도_1kHz소음",
    "20cm_정면_40cm_45도_1kHz소음",
    "20cm_정면_40cm_90도_1kHz소음"
]

def get_rms_db(audio_data):
    rms = np.sqrt(np.mean(np.square(audio_data)))
    return 20 * np.log10(rms + 1e-12)

# --- [빔포밍 함수 섹션] ---

def estimate_delay_gcc_phat(sig1, sig2, fs):
    """GCC-PHAT를 이용해 두 신호 간의 실제 도달 시간차(Delay)를 동적으로 추정"""
    n = len(sig1) + len(sig2) - 1
    N_fft = 1 << (n-1).bit_length()
    
    X1 = np.fft.rfft(sig1, n=N_fft)
    X2 = np.fft.rfft(sig2, n=N_fft)
    S = X1 * np.conj(X2)
    
    S_phat = S / (np.abs(S) + 1e-10)
    
    cc = np.fft.irfft(S_phat, n=N_fft)
    cc = np.concatenate((cc[-N_fft//2:], cc[:N_fft//2]))
    shift = np.argmax(np.abs(cc)) - N_fft//2
    
    tau = shift / fs
    return tau

def apply_beamforming_adaptive(stereo_data):
    """[적응형 빔포밍] GCC-PHAT로 위치를 추적하여 위상 정렬 후 합산"""
    fs = RATE
    left = stereo_data[:, 0]
    right = stereo_data[:, 1]
    
    # 1. 실시간 딜레이 추정
    tau = estimate_delay_gcc_phat(left, right, fs)
    delay_samples = int(np.round(tau * fs))
    
    # 2. 위상 정렬 (데이터 왜곡 최소화를 위해 pad 사용)
    if delay_samples > 0:
        shifted_right = np.pad(right, (delay_samples, 0))[:-delay_samples]
        combined = (left + shifted_right) / 2.0
    elif delay_samples < 0:
        ds = abs(delay_samples)
        shifted_left = np.pad(left, (ds, 0))[:-ds]
        combined = (shifted_left + right) / 2.0
    else:
        combined = (left + right) / 2.0

    # 3. Whisper 인식률을 위한 정규화
    norm = np.max(np.abs(combined))
    if norm > 0:
        combined = combined / norm
        
    return combined.astype(np.float32)

