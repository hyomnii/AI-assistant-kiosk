def run_experiment():
    print(f"📦 Whisper 모델({MODEL_SIZE}) 로딩 중...")
    model = whisper.load_model(MODEL_SIZE)
    
    print("\n" + "="*55)
    print("  🔬 AI 키오스크 빔포밍 성능 평가 (적응형 모드)")
    print("="*55)
    
    for condition in EXPERIMENT_LIST:
        print("\n" + "─"*55)
        print(f"🚀 다음 실험 준비: [{condition}]")
        
        trial_results = []
        for i in range(1, TRIALS + 1):
            time.sleep(0.5)
            print(f"\n[시도 {i}/{TRIALS}] 대상: {condition}")
            input(f"📢 세팅 완료 후 [Enter]를 누르면 {RECORD_SEC}초 녹음 시작...")
            
            print(f"🔴 녹음 중...")
            raw = sd.rec(int(RECORD_SEC * RATE), samplerate=RATE, channels=CHANNELS)
            sd.wait()
            
            # 분석 (적응형 함수 호출로 변경됨)
            audio_n = np.mean(raw, axis=1)
            audio_b = apply_beamforming_adaptive(raw)
            
            # Whisper 전사
            txt_n = model.transcribe(audio_n, language="ko", fp16=False)['text'].strip()
            txt_b = model.transcribe(audio_b, language="ko", fp16=False)['text'].strip()
            
            trial_results.append({
                'db_n': get_rms_db(audio_n),
                'db_b': get_rms_db(audio_b),
                'txt_n': txt_n,
                'txt_b': txt_b
            })
            print(f"    ✅ {i}회차 분석 완료")

        # --- [캡처용 최종 리포트 출력] ---
        avg_n = np.mean([r['db_n'] for r in trial_results])
        avg_b = np.mean([r['db_b'] for r in trial_results])
        
        print("\n" + "★"*45)
        print(f"📋 [실험 리포트] : {condition}") 
        print(f"1. 일반 평균 파워: {avg_n:.2f} dB")
        print(f"2. 빔포 평균 파워: {avg_b:.2f} dB")
        print(f"🔥 소음 억제 이득(Gain): {avg_n - avg_b:.2f} dB")
        print("-" * 45)
        print(f"[일반 모드 인식 결과]")
        for r in trial_results: print(f" - {r['txt_n']}")
        print("-" * 45)
        print(f"[빔포밍 모드 인식 결과]")
        for r in trial_results: print(f" - {r['txt_b']}")
        print("★"*45)
        
        cont = input("\n📸 캡처가 끝났으면 [Enter]를 눌러 다음 실험으로 이동 ('q'는 종료): ")
        if cont.lower() == 'q': break

    print("\n모든 실험 리스트가 완료되었습니다. 수고하셨습니다!")

if __name__ == "__main__":
    run_experiment()